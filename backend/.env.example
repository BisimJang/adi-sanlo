# ─────────────────────────────────────────
# Nomba Sandbox Credentials
# Get these from your Nomba sandbox dashboard
# ─────────────────────────────────────────
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
NOMBA_WEBHOOK_SECRET=
NOMBA_BASE_URL=https://sandbox.nomba.com

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/adisanlo

# ─────────────────────────────────────────
# Redis (for Celery job queue)
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change_this_to_a_random_secret
